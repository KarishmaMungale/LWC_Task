<?xml version="1.0" encoding="UTF-8"?>
<LightningMessageChannel xmlns="http://soap.sforce.com/2006/04/metadata">
    <description>Published when dashboard filters are applied or reset; subscribers refresh wired Apex data.</description>
    <isExposed>true</isExposed>
    <lightningMessageFields>
        <fieldName>startDate</fieldName>
    </lightningMessageFields>
    <lightningMessageFields>
        <fieldName>endDate</fieldName>
    </lightningMessageFields>
    <lightningMessageFields>
        <fieldName>ownerId</fieldName>
    </lightningMessageFields>
    <lightningMessageFields>
        <fieldName>stageName</fieldName>
    </lightningMessageFields>
    <lightningMessageFields>
        <fieldName>refreshToken</fieldName>
    </lightningMessageFields>
    <masterLabel>Dashboard Filters</masterLabel>
</LightningMessageChannel>
